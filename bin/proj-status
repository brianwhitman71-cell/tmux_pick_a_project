#!/usr/bin/env bash
# proj-status — emit one picker line per project ON THIS HOST:
#   name <TAB> <dot> dir
# <dot> is green ● if the session is live right now, grey ○ otherwise.
# Local-only and instant (single-host model). Cross-host status is a later add.
set -uo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
REG="$REPO/projects.tsv"
self_host="${PROJ_HOST:-$(hostname -s)}"

live="$(tmux ls -F '#S' 2>/dev/null || true)"
is_live() { printf '%s\n' "$live" | grep -qxF "$1"; }

green=$'\e[32m●\e[0m'
grey=$'\e[90m○\e[0m'

awk -F'\t' '$1!~/^#/ && NF' "$REG" | while IFS=$'\t' read -r name host dir cmd; do
  [ "$host" = "$self_host" ] || continue
  if is_live "$name"; then dot="$green"; else dot="$grey"; fi
  printf '%s\t%s %s\n' "$name" "$dot" "$dir"
done

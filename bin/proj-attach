#!/usr/bin/env bash
# proj-attach <name> — runs ON the target host. Ensures the project's tmux
# session exists (creating it + launching its startcmd if needed), then either
# switch-client (if we're already inside tmux) or attach (fresh shell / ssh -t).
set -uo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
REG="$REPO/projects.tsv"
name="${1:?usage: proj-attach <name>}"

row="$(awk -F'\t' -v n="$name" '$1!~/^#/ && $1==n {print; exit}' "$REG")"
[ -n "$row" ] || { echo "proj-attach: unknown project '$name'" >&2; exit 1; }
IFS=$'\t' read -r pname phost pdir pcmd <<<"$row"
: "${pdir:=$HOME}"

# tmux rewrites '.' and ':' in session names to '_', so use a sanitized name for
# every tmux op while the registry/display keeps the human name (e.g. nixfred.com)
sess="$(printf '%s' "$name" | tr '.:' '__')"

if ! tmux has-session -t "=$sess" 2>/dev/null; then
  pane="$(tmux new-session -d -P -F '#{pane_id}' -s "$sess" -c "$pdir")"
  [ -n "${pcmd:-}" ] && tmux send-keys -t "$pane" "$pcmd" Enter
fi

if [ -n "${TMUX:-}" ]; then
  # already inside tmux: retarget the current client (no nesting)
  exec tmux switch-client -t "=$sess"
elif [ -t 0 ] || [ -t 1 ]; then
  # plain terminal, not in tmux: attach (this is the normal/expected path)
  exec tmux attach -t "=$sess"
else
  # no controlling terminal (script, or a Bash tool with no tty): can't attach.
  # The session is created and running — just tell the caller how to get in.
  echo "proj: session '$name' is ready and running on $(hostname -s)," >&2
  echo "      but there's no terminal here to attach to." >&2
  echo "      Open it from an interactive shell with:  pj $name" >&2
  exit 0
fi

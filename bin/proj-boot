#!/usr/bin/env bash
# proj-boot — (re)create THIS host's project sessions and launch their startcmd.
# Run at boot by the tmux-projects user service so sessions exist before login,
# surviving reboots. Idempotent: existing sessions are left alone.
set -uo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
REG="$REPO/projects.tsv"
self_host="${PROJ_HOST:-$(hostname -s)}"

awk -F'\t' '$1!~/^#/ && NF' "$REG" | while IFS=$'\t' read -r name host dir cmd; do
  [ "$host" = "$self_host" ] || continue
  sess="$(printf '%s' "$name" | tr '.:' '__')"   # tmux-safe session name
  if tmux has-session -t "=$sess" 2>/dev/null; then
    echo "exists  $name"
    continue
  fi
  wdir="${dir:-$HOME}"; [ -d "$wdir" ] || wdir="$HOME"
  pane="$(tmux new-session -d -P -F '#{pane_id}' -s "$sess" -c "$wdir")"
  [ -n "${cmd:-}" ] && tmux send-keys -t "$pane" "$cmd" Enter
  echo "started $name  ($dir)"
done

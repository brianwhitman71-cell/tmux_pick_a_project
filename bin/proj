#!/usr/bin/env bash
# proj — pick a project (anywhere in the fleet) and jump into its tmux session.
# Local projects: switch-client/attach. Remote projects: hop over ssh -t.
# Close the window anytime; the session keeps running and `pj` brings you back.
set -uo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
REG="$REPO/projects.tsv"
BIN="$REPO/bin"
self_host="${PROJ_HOST:-$(hostname -s)}"
SSH_OPTS=(-o ConnectTimeout=2 -o BatchMode=yes -o StrictHostKeyChecking=accept-new)

usage() {
  cat <<'EOF'
proj / pj — project-centric tmux switcher (whole fleet)

  pj                      pick a project from the fleet, jump in
  pj <name>               jump straight in (local or remote — it figures it out)
  pj ls                   list all projects (this host + peers), with status
  pj here [name] [cmd]    keep the CURRENT tmux session as a project (this host)
  pj add <name> [dir] [cmd]   register a project on this host (dir = $PWD)
  pj rm <name>            retire a project on this host (asks before killing it)

● live   ○ stopped   (cyan host) = on another box, reached over ssh.
Close the window / drop ssh anytime — the session and anything in it keep
running. Come back with `pj <name>`. Default startcmd: cccc.
EOF
}

registered() { awk -F'\t' -v n="$1" -v h="$self_host" '$1!~/^#/ && $1==n && $2==h{f=1} END{exit !f}' "$REG"; }
peers() { [ -f "$REPO/peers" ] && grep -v '^#' "$REPO/peers" | sed '/^[[:space:]]*$/d' | grep -vxF "$self_host" || true; }

# which host owns <name>? prints host, or returns 1
resolve_host() {
  local n="$1" h
  registered "$n" && { echo "$self_host"; return 0; }
  for h in $(peers); do
    ssh "${SSH_OPTS[@]}" "$h" 'cat ~/Projects/tmux/projects.tsv 2>/dev/null' 2>/dev/null \
      | awk -F'\t' -v n="$n" '$1!~/^#/ && $1==n{f=1} END{exit !f}' \
      && { echo "$h"; return 0; }
  done
  return 1
}

case "${1:-}" in
  -h|--help|help) usage; exit 0 ;;

  ls) exec "$BIN/proj-status" --plain ;;

  add)
    shift
    name="${1:?usage: pj add <name> [dir] [cmd]}"; dir="${2:-$PWD}"; cmd="${3:-cccc}"
    registered "$name" && { echo "proj: '$name' already registered here" >&2; exit 1; }
    printf '%s\t%s\t%s\t%s\n' "$name" "$self_host" "$dir" "$cmd" >>"$REG"
    echo "added '$name' -> $self_host:$dir  ($cmd).  Start it with:  pj $name"
    exit 0 ;;

  here)
    shift
    if [ -z "${TMUX:-}" ]; then
      echo "proj here: you're not inside tmux, so there's no session to keep." >&2
      echo "Do one of these instead:" >&2
      echo "  • register + start fresh:   pj add ${1:-<name>} \$PWD && pj ${1:-<name>}" >&2
      echo "  • open tmux now, then keep: tmux new -s ${1:-<name>}   (then run: pj here)" >&2
      exit 1
    fi
    cur="$(tmux display-message -p '#S')"
    name="${1:-$cur}"; cmd="${2:-cccc}"
    dir="$(tmux display-message -p '#{pane_current_path}')"
    registered "$name" && { echo "proj: '$name' already registered (see: pj ls)" >&2; exit 1; }
    sess="$(printf '%s' "$name" | tr '.:' '__')"   # tmux rewrites . and : to _
    [ "$sess" != "$cur" ] && tmux rename-session "$sess"
    printf '%s\t%s\t%s\t%s\n' "$name" "$self_host" "$dir" "$cmd" >>"$REG"
    echo "kept '$name' -> $dir  ($cmd).  Rejoin anytime with:  pj $name"
    exit 0 ;;

  rm|remove)
    shift
    name="${1:?usage: pj rm <name>}"
    registered "$name" || { echo "proj: '$name' is not on $self_host (try on the host that owns it)" >&2; exit 1; }
    tmp="$(mktemp)"
    awk -F'\t' -v n="$name" '$1 ~ /^#/ || $1 != n {print}' "$REG" >"$tmp" && mv "$tmp" "$REG"
    echo "removed '$name' from $self_host registry"
    sess="$(printf '%s' "$name" | tr '.:' '__')"   # tmux rewrites . and : to _
    if tmux has-session -t "=$sess" 2>/dev/null; then
      read -r -p "kill the running '$name' session too (ends anything in it)? [y/N] " ans
      if [[ "$ans" =~ ^[Yy]$ ]]; then tmux kill-session -t "=$sess"; echo "killed '$name'"
      else echo "session '$name' left running"; fi
    fi
    exit 0 ;;
esac

# ---------------------------------------------------------------- jump --------
name="${1:-}"; host=""
if [ -z "$name" ]; then
  if ! { [ -t 0 ] && [ -t 1 ]; }; then
    echo "proj: open the picker from an interactive terminal, or use 'pj <name>'." >&2
    exit 1
  fi
  sel="$("$BIN/proj-status" | fzf --ansi --delimiter=$'\t' --with-nth=3 --nth=1,2 \
          --prompt='project> ' --height=60% --reverse \
          --header='enter = jump   |   ● live  ○ stopped   |   (cyan) = remote, via ssh' \
        || true)"
  [ -n "$sel" ] || exit 0
  name="$(cut -f1 <<<"$sel")"
  host="$(cut -f2 <<<"$sel")"
fi

if [ -z "$host" ]; then
  host="$(resolve_host "$name")" || {
    reach="$(peers | paste -sd' ' 2>/dev/null)"
    echo "proj: don't know a project called '$name' on $self_host${reach:+ or reachable peers ($reach)}." >&2
    echo "      If it lives on a box that's offline, bring that box up first." >&2
    echo "      Otherwise:  pj ls   (see all)    pj add $name <dir>   (register here)" >&2
    exit 1
  }
fi

if [ "$host" = "$self_host" ]; then
  exec "$BIN/proj-attach" "$name"
elif [ -n "${TMUX:-}" ]; then
  # already in tmux: the remote session opens NESTED. Ctrl-b d would detach THIS
  # box, not the remote — so tell the truth about the double prefix.
  echo "→ '$name' is on $host. You're inside tmux, so it opens nested over ssh." >&2
  echo "   Drive the remote with a DOUBLE prefix: Ctrl-b Ctrl-b <key>." >&2
  echo "   Return here:  Ctrl-b Ctrl-b d   (a plain Ctrl-b d detaches THIS box)." >&2
  exec ssh -t -o StrictHostKeyChecking=accept-new "$host" \
       "~/Projects/tmux/bin/proj-attach $(printf '%q' "$name")"
else
  echo "→ '$name' is on $host — hopping over ssh (Ctrl-b d to come back here)" >&2
  exec ssh -t -o StrictHostKeyChecking=accept-new "$host" \
       "~/Projects/tmux/bin/proj-attach $(printf '%q' "$name")"
fi
